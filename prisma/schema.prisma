generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  TRAINER
  HR
}

enum LearnerStatus {
  ACTIVE
  COMPLETED
  INACTIVE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum EnrollmentStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
}

enum MissionStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EmployeeStatus {
  AVAILABLE
  ASSIGNED
  INACTIVE
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CashType {
  INCOME
  EXPENSE
}

enum DocumentType {
  INVOICE
  RECEIPT
  CERTIFICATE
  TRANSCRIPT
  BADGE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role
  phone          String?
  mustChangePass Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoices       Invoice[] @relation("InvoiceCreatedBy")
  payments       Payment[] @relation("PaymentRecordedBy")
}

model Learner {
  id                          String          @id @default(cuid())
  registrationNo              String          @unique
  firstName                   String
  lastName                    String
  email                       String?
  phone                       String
  gender                      String?
  birthDate                   DateTime?
  birthPlace                  String?
  address                     String?
  occupation                  String?
  photoUrl                    String?
  emergencyContactFirstName   String?
  emergencyContactLastName    String?
  emergencyPhone              String?
  status                      LearnerStatus   @default(ACTIVE)
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  enrollments                 Enrollment[]
  serviceMissions ServiceMission[]
}

model Training {
  id          String       @id @default(cuid())
  title       String
  code        String       @unique
  category    String
  description String?
  durationDays Int
  fee         Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sessions    TrainingSession[]
}

model TrainingSession {
  id            String       @id @default(cuid())
  name          String
  sessionNumber Int
  location      String?
  startDate     DateTime
  endDate       DateTime
  trainerName   String?
  trainingId    String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  training      Training     @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  enrollments   Enrollment[]
}

model OperatorType {
  id          String       @id @default(cuid())
  name        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
}

model TrainingModule {
  id                String             @id @default(cuid())
  name              String             @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  enrollmentModules EnrollmentModule[]
}

model TrainingLocation {
  id          String       @id @default(cuid())
  name        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
}

model DurationOption {
  id          String       @id @default(cuid())
  label       String       @unique
  months      Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
}

model PaymentModeOption {
  id          String       @id @default(cuid())
  label       String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
}

model PaymentInstallment {
  id          String       @id @default(cuid())
  label       String       @unique
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  payments    Payment[]
}

model Enrollment {
  id                    String             @id @default(cuid())
  learnerId             String
  trainingSessionId     String
  matricule             String             @unique
  registrationDate      DateTime           @default(now())
  operatorTypeId        String?
  trainingLocationId    String?
  durationOptionId      String?
  paymentModeOptionId   String?
  registrationFee       Decimal            @default(0) @db.Decimal(12, 2)
  trainingFee           Decimal            @default(0) @db.Decimal(12, 2)
  totalFee              Decimal            @default(0) @db.Decimal(12, 2)
  amountPaid            Decimal            @default(0) @db.Decimal(12, 2)
  amountDue             Decimal            @default(0) @db.Decimal(12, 2)
  paymentStatus         PaymentStatus      @default(UNPAID)
  status                EnrollmentStatus   @default(PENDING)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  learner               Learner            @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  trainingSession       TrainingSession    @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  operatorType          OperatorType?      @relation(fields: [operatorTypeId], references: [id], onDelete: SetNull)
  trainingLocation      TrainingLocation?  @relation(fields: [trainingLocationId], references: [id], onDelete: SetNull)
  durationOption        DurationOption?    @relation(fields: [durationOptionId], references: [id], onDelete: SetNull)
  paymentModeOption     PaymentModeOption? @relation(fields: [paymentModeOptionId], references: [id], onDelete: SetNull)
  certificate           Certificate?
  invoices              Invoice[]
  payments              Payment[]
  documents             Document[]
  enrollmentModules     EnrollmentModule[]
  notes                 Note[]
}

model EnrollmentModule {
  id               String         @id @default(cuid())
  enrollmentId     String
  trainingModuleId String
  scoreTheory      Decimal?       @db.Decimal(5, 2)
  scorePractical   Decimal?       @db.Decimal(5, 2)
  averageScore     Decimal?       @db.Decimal(5, 2)
  observation      String?
  resultLabel      String?
  status           EnrollmentStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  enrollment       Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  trainingModule   TrainingModule @relation(fields: [trainingModuleId], references: [id], onDelete: Restrict)

  @@unique([enrollmentId, trainingModuleId])
}

model Note {
  id           String      @id @default(cuid())
  content      String
  enrollmentId String?
  employeeId   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  employee     Employee?   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Availability {
  id          String     @id @default(cuid())
  label       String     @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Certificate {
  id               String     @id @default(cuid())
  enrollmentId     String     @unique
  certificateNo    String     @unique
  verificationCode String     @unique
  issuedAt         DateTime   @default(now())
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model ServiceProvider {
  id                 String           @id @default(cuid())
  fullName           String
  phone              String
  secondaryPhone     String?
  email              String?
  category           String
  address            String?
  birthDate          DateTime?
  birthPlace         String?
  nationality        String?
  maritalStatus      String?
  idType             String?
  idNumber           String?
  idExpiryDate       DateTime?
  hasIdCopy          Boolean          @default(false)
  availability       String?
  workZone           String?
  hasExperience      Boolean          @default(false)
  experienceEmployer String?
  experiencePosition String?
  experienceDuration String?
  experienceContact  String?
  skills             String[]
  guarantorName      String?
  guarantorRelation  String?
  guarantorPhone     String?
  guarantorAddress   String?
  guarantorHasIdCopy Boolean          @default(false)
  interviewFavorable Boolean?
  fileComplete       Boolean          @default(false)
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  missions           ServiceMission[]
}

model Household {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  managerName    String
  phone          String
  address        String?
  requestedService String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignments    Assignment[]
}

model Employee {
  id             String         @id @default(cuid())
  employeeNo     String         @unique
  fullName       String
  phone          String
  address        String?
  competency     String
  availabilityId String?
  status         EmployeeStatus @default(AVAILABLE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assignments    Assignment[]
  notes          Note[]
  availability   Availability?  @relation(fields: [availabilityId], references: [id], onDelete: SetNull)
}

model Assignment {
  id           String           @id @default(cuid())
  employeeId   String
  householdId  String
  serviceLabel String
  startDate    DateTime
  endDate      DateTime?
  notes        String?
  status       AssignmentStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  household    Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
}

model ServiceMission {
  id                   String           @id @default(cuid())
  missionNo            String           @unique
  clientName           String
  clientPhone          String?
  clientSecondaryPhone String?
  clientEmail          String?
  clientProfession     String?
  clientDistrict       String?
  location             String
  numberOfPeople       String?
  serviceType          String
  startDate            DateTime
  endDate              DateTime?
  schedule             String?
  details              String?
  amount               Decimal          @db.Decimal(12, 2)
  status               MissionStatus    @default(DRAFT)
  providerId           String?
  learnerId            String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  provider             ServiceProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  learner              Learner?         @relation(fields: [learnerId], references: [id], onDelete: SetNull)
  invoices             Invoice[]
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNo     String        @unique
  clientName    String
  description   String
  amount        Decimal       @db.Decimal(12, 2)
  dueDate       DateTime
  status        InvoiceStatus @default(ISSUED)
  missionId     String?
  enrollmentId  String?
  assignmentId  String?
  issuedById    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  mission       ServiceMission? @relation(fields: [missionId], references: [id], onDelete: SetNull)
  enrollment    Enrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  assignment    Assignment?   @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  issuedBy      User          @relation("InvoiceCreatedBy", fields: [issuedById], references: [id], onDelete: Restrict)
  payments      Payment[]
  documents     Document[]
}

model Payment {
  id            String        @id @default(cuid())
  paymentNo     String        @unique
  invoiceId     String?
  enrollmentId  String?
  installmentId String?
  amount        Decimal       @db.Decimal(12, 2)
  paidAt        DateTime
  method        PaymentMethod
  reference     String?
  comment       String?
  recordedById  String
  createdAt     DateTime      @default(now())
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  enrollment    Enrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  installment   PaymentInstallment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  recordedBy    User          @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)
  receipt       Receipt?
  cashEntries   CashEntry[]
}

model Receipt {
  id         String   @id @default(cuid())
  receiptNo  String   @unique
  paymentId  String   @unique
  issuedAt   DateTime @default(now())
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model CashEntry {
  id            String    @id @default(cuid())
  entryNo       String    @unique
  date          DateTime
  label         String
  type          CashType
  amount        Decimal   @db.Decimal(12, 2)
  balanceAfter  Decimal   @db.Decimal(12, 2)
  justification String?
  paymentId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payment       Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
}

model Document {
  id            String       @id @default(cuid())
  documentNo    String       @unique
  type          DocumentType
  status        String       @default("Generated")
  enrollmentId  String?
  invoiceId     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  enrollment    Enrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}
