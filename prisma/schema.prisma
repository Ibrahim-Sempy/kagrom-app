generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  TRAINER
  HR
}

enum LearnerStatus {
  ACTIVE
  COMPLETED
  INACTIVE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum EnrollmentStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
}

enum MissionStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum avisType {
  FAVORABLE
  UNFAVORABLE
  MONITOR
}

enum typeInvoice {
  client
  learner
}

enum EmployeeStatus {
  AVAILABLE
  ASSIGNED
  INACTIVE
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CashType {
  INCOME
  EXPENSE
}

enum DocumentType {
  INVOICE
  RECEIPT
  CERTIFICATE
  TRANSCRIPT
  BADGE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum matrialStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum typeOfId {
  NATIONAL_ID
  PASSPORT
  OTHER
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role
  phone          String?
  mustChangePass Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // FIX: ces relations étaient référencées mais Invoice/Payment n'avaient pas les champs inverses
  // Supprimées car Invoice et Payment n'ont plus issuedById / recordedById dans le schéma actuel
}

model Learner {
  id                        String        @id @default(cuid())
  registrationNo            String        @unique
  firstName                 String
  lastName                  String
  email                     String?
  phone                     String
  gender                    String?
  birthDate                 DateTime?
  birthPlace                String?
  address                   String?
  occupation                String?
  photoUrl                  String?
  emergencyContactFirstName String?
  emergencyContactLastName  String?
  emergencyPhone            String?
  status                    LearnerStatus @default(ACTIVE)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  enrollments               Enrollment[]
  notes                     Note[]        // FIX: champ inverse pour Note.learner
  // FIX: "services" retiré — Service n'a pas de relation vers Learner
}

model Session {
  id          String       @id @default(cuid())
  label       String
  startDate   DateTime?
  endDate     DateTime?
  trainerName String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
}

model OperatorType {
  id              String           @id @default(cuid())
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  trainingModules TrainingModule[] // FIX: champ inverse pour TrainingModule.operatorType
  // FIX: "enrollments" retiré — Enrollment n'a plus operatorTypeId
}

model TrainingModule {
  id                String             @id @default(cuid())
  name              String             @unique
  OperatorTypeId    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  enrollmentModules EnrollmentModule[]
  operatorType      OperatorType?      @relation(fields: [OperatorTypeId], references: [id], onDelete: SetNull)
  notes             Note[]             // FIX: champ inverse pour Note.module
  enrollments       Enrollment[]       @relation("EnrollmentModules") // FIX: many-to-many nommé
}

model TrainingLocation {
  id          String       @id @default(cuid())
  name        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
}

model DurationOption {
  id          String       @id @default(cuid())
  label       String       @unique
  months      Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  personalTrainings PersonalTraining[] // FIX: champ inverse pour PersonalTraining.duree
}

model PaymentModeOption {
  id          String       @id @default(cuid())
  label       String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  payments    Payment[]    // FIX: champ inverse pour Payment.paymentModeOption
}

model PaymentInstallment {
  id        String    @id @default(cuid())
  label     String    @unique
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]
}

model Service {
  id                  String        @id @default(cuid())
  label               String        @unique
  description         String?
  status              ServiceStatus @default(ACTIVE)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  posteEmployees      Employee[]    @relation("PosteDemanded")
  competencyEmployees Employee[]    @relation("Competencies")
  assignments         Assignment[]  @relation("AssignmentServices") // FIX: champ inverse pour Assignment.services
  personalTrainings   PersonalTraining[]
}

model Enrollment {
  id                  String             @id @default(cuid())
  learnerId           String
  SessionId           String
  registrationDate    DateTime           @default(now())
  trainingLocationId  String?
  durationOptionId    String?
  paymentModeOptionId String?
  registrationFee     Decimal            @default(0) @db.Decimal(12, 2)
  trainingFee         Decimal            @default(0) @db.Decimal(12, 2)
  totalFee            Decimal            @default(0) @db.Decimal(12, 2)
  amountPaid          Decimal            @default(0) @db.Decimal(12, 2)
  amountDue           Decimal            @default(0) @db.Decimal(12, 2)
  paymentStatus       PaymentStatus      @default(UNPAID)
  status              EnrollmentStatus   @default(PENDING)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  learner             Learner            @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  Session             Session            @relation(fields: [SessionId], references: [id], onDelete: Cascade)
  trainingLocation    TrainingLocation?  @relation(fields: [trainingLocationId], references: [id], onDelete: SetNull)
  durationOption      DurationOption?    @relation(fields: [durationOptionId], references: [id], onDelete: SetNull)
  paymentModeOption   PaymentModeOption? @relation(fields: [paymentModeOptionId], references: [id], onDelete: SetNull)
  certificate         Certificate?
  invoices            Invoice[]          @relation("EnrollmentInvoices") // FIX: relation nommée
  payments            Payment[]
  documents           Document[]
  enrollmentModules   EnrollmentModule[]
  // notes               Note[]
  modules             TrainingModule[]   @relation("EnrollmentModules") // FIX: many-to-many nommé
}

model EnrollmentModule {
  id               String         @id @default(cuid())
  enrollmentId     String
  trainingModuleId String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  enrollment       Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  trainingModule   TrainingModule @relation(fields: [trainingModuleId], references: [id], onDelete: Restrict)

  @@unique([enrollmentId, trainingModuleId])
}

model Note {
  id             String          @id @default(cuid())
  learnerId      String?
  moduleId       String?
  // employeeId     String?
  enrollmentId   String?         // FIX: ajout du champ FK pour la relation avec Enrollment
  scoreTheory    Decimal?        @db.Decimal(5, 2)
  scorePractical Decimal?        @db.Decimal(5, 2)
  observation    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  learner        Learner?        @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  // employee       Employee?       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  module         TrainingModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  // enrollment     Enrollment?     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model Availability {
  id          String       @id @default(cuid())
  label       String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  employees   Employee[]
  assignments Assignment[] @relation("AssignmentHoraire") // FIX: champ inverse pour Assignment.horaire
}

model Certificate {
  id               String     @id @default(cuid())
  enrollmentId     String     @unique
  certificateNo    String     @unique
  verificationCode String     @unique
  issuedAt         DateTime   @default(now())
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model Household {
  id             String       @id @default(cuid())
  firstName      String
  lastName       String
  address        String?
  quartier       String?
  primaryPhone   String
  secondaryPhone String?
  email          String?
  profession     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignments    Assignment[] // FIX: champ inverse pour Assignment.household
}

model Employee {
  id                 String        @id @default(cuid())
  firstName          String
  lastName           String
  birthDate          DateTime?
  birthPlace         String?
  nationality        String?
  matrialStatus      matrialStatus
  address            String
  primaryPhone       String
  secondaryPhone     String?
  typeOfId           typeOfId
  idNumber           String?
  idExpiryDate       DateTime?
  hasIdCopy          Boolean       @default(false)
  guarantorfirstName String?
  guarantorLastName  String?
  guarantorRelation  String?
  guarantorAddress   String?
  guarantorPhone     String?
  completeFolder     Boolean       @default(false)
  interviewDone      Boolean?
  avis               avisType?
  observations       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  availability       Availability[]
  posteDemanded      Service[]     @relation("PosteDemanded")
  competencies       Service[]     @relation("Competencies")
  assignments        Assignment[]  // FIX: champ inverse pour Assignment.employee
  personalTrainings   PersonalTraining[]
  // notes              Note[]        // FIX: champ inverse pour Note.employee
}

model Assignment {
  id           String           @id @default(cuid())
  employeeId   String
  householdId  String
  monthlyAmount Decimal          @db.Decimal(12, 2) @default(0)
  startDate    DateTime
  numberPerson Int
  notes        String?
  status       AssignmentStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  household    Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invoices     Invoice[]        @relation("AssignmentInvoices") // FIX: relation nommée
  services     Service[]        @relation("AssignmentServices") // FIX: many-to-many nommé
  horaire      Availability[]   @relation("AssignmentHoraire")  // FIX: many-to-many nommé
}

model Invoice {
  id           String        @id @default(cuid())
  invoiceNo    String        @unique
  type         typeInvoice   @default(client)
  enrollmentId String?
  assignmentId String?
  ammount      Decimal       @db.Decimal(12, 2)
  dueDate      DateTime
  description  String?
  status       InvoiceStatus @default(ISSUED)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  enrollment   Enrollment?   @relation("EnrollmentInvoices", fields: [enrollmentId], references: [id], onDelete: SetNull) // FIX: relation nommée
  assignment   Assignment?   @relation("AssignmentInvoices", fields: [assignmentId], references: [id], onDelete: SetNull) // FIX: relation nommée
  payments     Payment[]     // FIX: champ inverse pour Payment.invoice
  documents    Document[]
}

model Payment {
  id              String              @id @default(cuid())
  paymentNo       String              @unique
  invoiceId       String?
  enrollmentId    String?
  installmentId   String?
  paymentModeId   String?             // FIX: FK scalaire remplaçant la mauvaise relation "method"
  amount          Decimal             @db.Decimal(12, 2)
  paidAt          DateTime
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  invoice         Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  enrollment      Enrollment?         @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  installment     PaymentInstallment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  paymentMode     PaymentModeOption?  @relation(fields: [paymentModeId], references: [id], onDelete: SetNull) // FIX: relation correcte avec FK
  receipt         Receipt?
  cashEntries     CashEntry[]
}

model Receipt {
  id        String   @id @default(cuid())
  receiptNo String   @unique
  paymentId String   @unique
  issuedAt  DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model CashEntry {
  id            String    @id @default(cuid())
  date          DateTime
  label         String
  type          CashType
  amount        Decimal   @db.Decimal(12, 2)
  justification String?
  paymentId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payment       Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
}

model Document {
  id           String       @id @default(cuid())
  documentNo   String       @unique
  type         DocumentType
  status       String       @default("Generated")
  enrollmentId String?
  invoiceId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  enrollment   Enrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

// ajouter formation personnelle et une tables note pour les employés
model PersonalTraining {
  id          String    @id @default(cuid())
  employeeId  String
  serviceId   String
  dureeId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  duree       DurationOption @relation(fields: [dureeId], references: [id], onDelete: Restrict)
  personalNote NoteEmployee? // FIX: relation vers les notes spécifiques aux employés
}


model NoteEmployee {
  id             String          @id @default(cuid())
  personalTrainingId String      @unique
  scoreTheory    Decimal?        @db.Decimal(5, 2)
  scorePractical Decimal?        @db.Decimal(5, 2)
  observation    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  personalTraining PersonalTraining @relation(fields: [personalTrainingId], references: [id], onDelete: Cascade)
}
